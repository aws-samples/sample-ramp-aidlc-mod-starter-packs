# =============================================================================
# Dockerfile for Agentic AI Agent (ECS Fargate)
# Generated by: AWS Agentic AI Pattern Optimizer
#
# Use Case: {{USE_CASE}}
# Framework: {{FRAMEWORK}}
# Deployment: AWS ECS Fargate
# =============================================================================

# Use AWS-provided Python base image for compatibility
FROM public.ecr.aws/lambda/python:3.11 AS builder

# Install build dependencies
RUN pip install --upgrade pip

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt -t /opt/python

# =============================================================================
# Production image
# =============================================================================

FROM python:3.11-slim

# Security: Run as non-root user
RUN groupadd -r agent && useradd -r -g agent agent

# Set working directory
WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /opt/python /usr/local/lib/python3.11/site-packages

# Copy application code
COPY src/ ./src/

# Set Python path
ENV PYTHONPATH=/app/src
ENV PYTHONUNBUFFERED=1

# Default environment variables
ENV PORT=8080
ENV AWS_REGION=us-east-1
ENV MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Expose port for health checks
EXPOSE 8080

# Switch to non-root user
USER agent

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Start the application with gunicorn
CMD ["gunicorn", "--bind", "0.0.0.0:8080", "--workers", "2", "--threads", "4", "--timeout", "120", "src.agent:app"]
